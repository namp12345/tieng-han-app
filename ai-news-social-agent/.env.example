# ╔══════════════════════════════════════════════════════════════╗
# ║           AI News Social Agent — Cấu hình                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Chọn AI provider (mặc định: gemini — miễn phí) ──────────────
# Tuỳ chọn: gemini | groq | ollama | openai | deepseek
AI_PROVIDER=gemini

# ── OPTION 1: Google Gemini (MIỄN PHÍ ✅) ───────────────────────
# Đăng ký tại: https://aistudio.google.com
# → Nhấn "Get API key" → Tạo key → Copy vào đây
# Giới hạn free: 1,500 yêu cầu/ngày | 1,000,000 tokens/ngày
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── OPTION 2: Groq (MIỄN PHÍ ✅, siêu nhanh) ───────────────────
# Đăng ký tại: https://console.groq.com (dùng Google/GitHub)
# → Settings → API Keys → Create API Key
# Giới hạn free: 6,000 tokens/phút | không giới hạn req/ngày
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ── OPTION 3: Ollama (MIỄN PHÍ HOÀN TOÀN, chạy offline ✅) ─────
# Cài đặt: https://ollama.ai → sau đó chạy: ollama pull gemma2:2b
# Không cần internet sau khi tải model (model ~1.6GB)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma2:2b

# ── OPTION 4: OpenAI (trả phí) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── OPTION 5: DeepSeek (trả phí, rẻ ~10x so với OpenAI) ────────
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# ── Telegram Bot (MIỄN PHÍ ✅) ──────────────────────────────────
# 1. Nhắn @BotFather trên Telegram → /newbot → lấy token
# 2. Nhắn @userinfobot → lấy chat ID của bạn
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Cài đặt hệ thống ────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_NEWS_PER_RUN=20
MIN_IMPORTANCE_SCORE=5
# Delay (giây) giữa các lần gọi AI — tránh bị rate limit free tier
AI_RATE_LIMIT_DELAY=2
